# =============================================================================
# WhatsApp AI SaaS -- Environment Variables
# Copy this file to infra/.env and fill in all REQUIRED values before running.
# =============================================================================

# SHARED / GENERAL
NODE_ENV=development
LOG_LEVEL=info

# POSTGRESQL
POSTGRES_PASSWORD=changeme_postgres

# REDIS (per-user ACL passwords -- least-privilege)
REDIS_GATEWAY_PASSWORD=changeme_gw
REDIS_FLOW_ENGINE_PASSWORD=changeme_fe
REDIS_TENANT_API_PASSWORD=changeme_ta
REDIS_RAG_INDEXER_PASSWORD=changeme_ri
REDIS_DEFAULT_PASSWORD=changeme_default

# MINIO / OBJECT STORAGE
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio
S3_BUCKET_KB=kb-documents
S3_REGION=us-east-1

# META / WHATSAPP -- REQUIRED
META_APP_SECRET=REPLACE_WITH_META_APP_SECRET
META_VERIFY_TOKEN=REPLACE_WITH_VERIFY_TOKEN
META_API_BASE=https://graph.facebook.com/v21.0

# JWT AUTH -- REQUIRED (openssl rand -hex 32)
JWT_SECRET=REPLACE_WITH_JWT_SECRET
JWT_EXPIRES_IN=12h

# ENCRYPTION -- REQUIRED (openssl rand -hex 32)
MASTER_KEY=REPLACE_WITH_MASTER_KEY

# INTER-SERVICE AUTH -- REQUIRED (openssl rand -hex 32)
INTERNAL_API_TOKEN=REPLACE_WITH_INTERNAL_TOKEN

# FLOW ENGINE
FLOW_ENGINE_MODE=both
FLOW_ENGINE_WORKER_COUNT=4
STREAM_BLOCK_MS=5000
LOCK_TTL_SECONDS=30
IDEMPOTENCY_TTL_SECONDS=300
FLOW_CACHE_TTL_SECONDS=60

# LLM
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.3
OPENAI_API_KEY=

# EMBEDDINGS & RAG
EMBEDDER_DEFAULT=sbert
RAG_DEFAULT_CONFIDENCE=0.55

# RAG INDEXER
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=50
EMBED_BATCH_SIZE=32
HEARTBEAT_INTERVAL_SECONDS=15
RAG_INDEXER_WORKER_COUNT=2

# CHROMADB (leave empty to disable auth)
CHROMA_SERVER_AUTHN_CREDENTIALS=

# GRAFANA
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_grafana

# POSTGRESQL BACKUPS
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=7
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=6

# GATEWAY
TENANT_CACHE_TTL_SECONDS=300
STREAM_MAXLEN_APPROX=10000

# TENANT API
CORS_ORIGINS=http://localhost:5173
ARGON2_MEMORY_COST_KB=65536
