{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whatsapp-ai-saas/contracts/flow-engine-message.schema.json",
  "title": "FlowEngineMessage",
  "description": "Envelope pushed by gateway onto the Redis Stream flow-engine:{tenant_id}. The 'data' field of each stream entry contains a JSON-serialised instance of this schema.",
  "type": "object",
  "required": [
    "message_id",
    "received_at",
    "tenant_id",
    "phone_number_id",
    "raw"
  ],
  "additionalProperties": false,
  "properties": {
    "message_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUIDv4 generated by gateway at ingestion time. Used as the idempotency key in flow-engine."
    },
    "received_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp at which gateway received the webhook."
    },
    "tenant_id": {
      "type": "string",
      "format": "uuid",
      "description": "Tenant UUID resolved by gateway from the phone_number_id."
    },
    "phone_number_id": {
      "type": "string",
      "description": "Meta phone number ID from the webhook metadata. Used to identify which WABA the message arrived on."
    },
    "raw": {
      "type": "object",
      "description": "The full Meta Cloud API value object as received by gateway (value field inside changes[].value). Preserved verbatim for auditability.",
      "required": ["messaging_product", "metadata"],
      "properties": {
        "messaging_product": {
          "type": "string",
          "const": "whatsapp"
        },
        "metadata": {
          "type": "object",
          "required": ["phone_number_id"],
          "properties": {
            "display_phone_number": { "type": "string" },
            "phone_number_id": { "type": "string" }
          }
        },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "profile": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" }
                }
              },
              "wa_id": { "type": "string" }
            }
          }
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "id", "timestamp", "type"],
            "properties": {
              "from": {
                "type": "string",
                "description": "Sender's WhatsApp ID (phone number without +)"
              },
              "id": {
                "type": "string",
                "description": "Meta-assigned message ID (wamid...)"
              },
              "timestamp": {
                "type": "string",
                "description": "Unix timestamp as string (Meta format)"
              },
              "type": {
                "type": "string",
                "enum": ["text", "interactive", "image", "document", "audio", "video", "sticker", "location", "contacts", "reaction", "order", "system", "unknown"]
              },
              "text": {
                "type": "object",
                "properties": {
                  "body": { "type": "string" }
                }
              },
              "interactive": {
                "type": "object"
              }
            }
          }
        },
        "statuses": {
          "type": "array",
          "description": "Delivery/read receipts — present when the webhook is a status update rather than an inbound message",
          "items": { "type": "object" }
        }
      }
    }
  }
}
